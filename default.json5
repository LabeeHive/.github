{
  assignees: ["corrupt952"],
  reviewers: ["corrupt952"],

  extends: [
    "config:best-practices",

    // https://docs.renovatebot.com/presets-default/
    ":timezone(Asia/Tokyo)",
    ":prHourlyLimitNone",
    ":prConcurrentLimitNone",
    'schedule:earlyMondays',

    // Keep biome.json $schema version in sync with @biomejs/biome package
    "customManagers:biomeVersions",
  ],

  // Automerge
  platformAutomerge: true,
  automergeStrategy: "squash",

  // Package rules
  packageRules: [
    {
      matchUpdateTypes: ["minor", "patch", "pin", "digest"],
      automerge: true,
    },
    {
      groupName: "cloudflare workers-sdk",
      matchSourceUrls: ["https://github.com/cloudflare/workers-sdk"],
    },
  ],
}
